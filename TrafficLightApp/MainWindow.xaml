<Window x:Class="ClaudeTrafficLight.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Claude Traffic Light"
        Width="120"
        Height="200"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        x:Name="windowRoot">
    <Window.Resources>
        <!-- 呼吸动画 -->
        <Storyboard x:Key="BreatheAnimation" RepeatBehavior="Forever">
            <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="Opacity">
                <EasingDoubleKeyFrame KeyTime="0:0:0" Value="0.7"/>
                <EasingDoubleKeyFrame KeyTime="0:0:0.6" Value="1.0"/>
                <EasingDoubleKeyFrame KeyTime="0:0:1.2" Value="0.7"/>
            </DoubleAnimationUsingKeyFrames>
        </Storyboard>

        <!-- 气泡入场动画 -->
        <Storyboard x:Key="BubbleEnterAnimation">
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.2"/>
            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.X"
                             From="-5" To="0" Duration="0:0:0.2"/>
        </Storyboard>

        <!-- 气泡退场动画 -->
        <Storyboard x:Key="BubbleExitAnimation">
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                             From="1" To="0" Duration="0:0:0.2"/>
        </Storyboard>

        <!-- 径向渐变画笔 - 亮灯 -->
        <RadialGradientBrush x:Key="YellowOnBrush" GradientOrigin="0.3,0.3" Center="0.5,0.5" RadiusX="0.6" RadiusY="0.6">
            <GradientStop Color="#FFE066" Offset="0"/>
            <GradientStop Color="#FFD700" Offset="0.4"/>
            <GradientStop Color="#CC8400" Offset="1"/>
        </RadialGradientBrush>
        <RadialGradientBrush x:Key="GreenOnBrush" GradientOrigin="0.3,0.3" Center="0.5,0.5" RadiusX="0.6" RadiusY="0.6">
            <GradientStop Color="#66FF99" Offset="0"/>
            <GradientStop Color="#00FF7F" Offset="0.4"/>
            <GradientStop Color="#009933" Offset="1"/>
        </RadialGradientBrush>
        <RadialGradientBrush x:Key="RedOnBrush" GradientOrigin="0.3,0.3" Center="0.5,0.5" RadiusX="0.6" RadiusY="0.6">
            <GradientStop Color="#FF6666" Offset="0"/>
            <GradientStop Color="#FF4444" Offset="0.4"/>
            <GradientStop Color="#990000" Offset="1"/>
        </RadialGradientBrush>

        <!-- 灭灯画笔 -->
        <SolidColorBrush x:Key="OffBrush" Color="#3A3A3A"/>

        <!-- 边框画笔 -->
        <SolidColorBrush x:Key="BorderLightBrush" Color="#FFFFFF" Opacity="0.15"/>
        <SolidColorBrush x:Key="BorderDarkBrush" Color="#000000" Opacity="0.3"/>

        <!-- 气泡背景 -->
        <SolidColorBrush x:Key="BubbleBackground" Color="#4A4A4A" Opacity="0.95"/>
        <SolidColorBrush x:Key="BubbleBorder" Color="#FFFFFF" Opacity="0.2"/>
    </Window.Resources>

    <Window.ContextMenu>
        <ContextMenu Opened="ContextMenu_Opened">
            <MenuItem Header="连接状态" Click="ShowConnectionStatus_Click">
                <MenuItem.Icon>
                    <TextBlock x:Name="ServerStatusIcon">🔌</TextBlock>
                </MenuItem.Icon>
            </MenuItem>
            <MenuItem Header="安装Claude Code Hooks" Click="InstallClaudeHooks_Click">
                <MenuItem.Icon>
                    <TextBlock>🔧</TextBlock>
                </MenuItem.Icon>
            </MenuItem>
            <MenuItem Header="卸载Claude Code Hooks" Click="UninstallClaudeHooks_Click">
                <MenuItem.Icon>
                    <TextBlock>🗑️</TextBlock>
                </MenuItem.Icon>
            </MenuItem>
            <MenuItem Header="重启WebSocket服务" Click="RestartWebSocket_Click">
                <MenuItem.Icon>
                    <TextBlock>🔄</TextBlock>
                </MenuItem.Icon>
            </MenuItem>
            <Separator/>
            <MenuItem Header="端口设置">
                <MenuItem.Icon>
                    <TextBlock>🔌</TextBlock>
                </MenuItem.Icon>
                <StackPanel Width="150" Margin="5">
                    <TextBlock Text="WebSocket 端口:" Margin="0,0,0,5"/>
                    <TextBox x:Name="PortTextBox" Text="19876" PreviewKeyDown="PortTextBox_PreviewKeyDown"/>
                    <Button Content="保存并重启" Click="SavePort_Click" Margin="0,5,0,0"/>
                </StackPanel>
            </MenuItem>
            <MenuItem Header="轮询间隔">
                <MenuItem.Icon>
                    <TextBlock>⏱️</TextBlock>
                </MenuItem.Icon>
                <StackPanel Width="180" Margin="5">
                    <TextBlock Text="文件轮询间隔 (毫秒):" Margin="0,0,0,5"/>
                    <TextBox x:Name="PollingIntervalTextBox" Text="500" PreviewKeyDown="PollingIntervalTextBox_PreviewKeyDown"/>
                    <TextBlock Text="建议范围: 100-5000ms" FontSize="10" Opacity="0.7" Margin="0,3,0,5"/>
                    <Button Content="保存" Click="SavePollingInterval_Click" Margin="0,0,0,0"/>
                </StackPanel>
            </MenuItem>
            <MenuItem Header="LED显示设置">
                <MenuItem.Icon>
                    <TextBlock>💡</TextBlock>
                </MenuItem.Icon>
                <StackPanel Width="200" Margin="5">
                    <CheckBox x:Name="StopScrollCheckBox" Content="滚动一轮后停止并清空" Margin="0,0,0,5"
                              Checked="StopScrollCheckBox_Changed" Unchecked="StopScrollCheckBox_Changed"/>
                    <TextBlock Text="滚动速度:" Margin="0,5,0,3"/>
                    <Slider x:Name="ScrollSpeedSlider" Minimum="0.2" Maximum="5.0" Value="0.8"
                            TickFrequency="0.2" IsSnapToTickEnabled="True"
                            ValueChanged="ScrollSpeedSlider_ValueChanged"/>
                    <TextBlock Text="{Binding Value, ElementName=ScrollSpeedSlider, StringFormat={}{0:F1} 像素/次}"
                               HorizontalAlignment="Center" FontSize="11" Opacity="0.7" Margin="0,3,0,5"/>
                    <Separator Margin="0,5,0,5"/>
                    <TextBlock Text="吸边灵敏度:" Margin="0,0,0,3"/>
                    <Slider x:Name="SnapThresholdSlider" Minimum="10" Maximum="150" Value="60"
                            TickFrequency="10" IsSnapToTickEnabled="True"
                            ValueChanged="SnapThresholdSlider_ValueChanged"/>
                    <TextBlock Text="{Binding Value, ElementName=SnapThresholdSlider, StringFormat={}{0} 像素}"
                               HorizontalAlignment="Center" FontSize="11" Opacity="0.7" Margin="0,3,0,5"/>
                    <Separator Margin="0,5,0,5"/>
                    <TextBlock Text="窗口总宽度:" Margin="0,0,0,3"/>
                    <TextBox x:Name="WindowWidthTextBox" Text="120" PreviewKeyDown="WindowWidthTextBox_PreviewKeyDown"/>
                    <TextBlock Text="信号灯宽度:" Margin="0,5,0,3"/>
                    <TextBox x:Name="LightWidthTextBox" Text="64" PreviewKeyDown="LightWidthTextBox_PreviewKeyDown"/>
                    <TextBlock Text="LED区域宽度:" Margin="0,5,0,3"/>
                    <TextBox x:Name="LedWidthTextBox" Text="30" PreviewKeyDown="LedWidthTextBox_PreviewKeyDown"/>
                    <Button Content="应用尺寸设置" Click="ApplySizeSettings_Click" Margin="0,8,0,0"/>
                </StackPanel>
            </MenuItem>
            <MenuItem Header="文案设置">
                <MenuItem.Icon>
                    <TextBlock>📝</TextBlock>
                </MenuItem.Icon>
                <StackPanel Width="220" Margin="5">
                    <TextBlock Text="🟡 黄灯（思考中）" FontWeight="Bold" Margin="0,0,0,3"/>
                    <TextBlock Text="标签文字:" Margin="0,0,0,2"/>
                    <TextBox x:Name="YellowLabelTextBox" Text="思考中" />
                    <TextBlock Text="消息文字:" Margin="0,5,0,2"/>
                    <TextBox x:Name="YellowMessageTextBox" Text="AI正在思考您的问题..." TextWrapping="Wrap" MinHeight="40"/>
                    <Separator Margin="0,8,0,8"/>
                    <TextBlock Text="🔴 红灯（需要确认）" FontWeight="Bold" Margin="0,0,0,3"/>
                    <TextBlock Text="标签文字:" Margin="0,0,0,2"/>
                    <TextBox x:Name="RedLabelTextBox" Text="需要确认" />
                    <TextBlock Text="消息文字:" Margin="0,5,0,2"/>
                    <TextBox x:Name="RedMessageTextBox" Text="请确认下一步操作..." TextWrapping="Wrap" MinHeight="40"/>
                    <Separator Margin="0,8,0,8"/>
                    <TextBlock Text="🟢 绿灯（输出中）" FontWeight="Bold" Margin="0,0,0,3"/>
                    <TextBlock Text="标签文字:" Margin="0,0,0,2"/>
                    <TextBox x:Name="GreenLabelTextBox" Text="输出中" />
                    <TextBlock Text="消息文字:" Margin="0,5,0,2"/>
                    <TextBox x:Name="GreenMessageTextBox" Text="正在生成回答..." TextWrapping="Wrap" MinHeight="40"/>
                    <Separator Margin="0,8,0,8"/>
                    <StackPanel Orientation="Horizontal">
                        <Button Content="恢复默认" Click="ResetTextSettings_Click" Margin="0,0,5,0"/>
                        <Button Content="保存设置" Click="SaveTextSettings_Click" HorizontalAlignment="Right"/>
                    </StackPanel>
                </StackPanel>
            </MenuItem>
            <MenuItem Header="动画设置">
                <MenuItem.Icon>
                    <TextBlock>🎬</TextBlock>
                </MenuItem.Icon>
                <StackPanel Width="240" Margin="5">
                    <CheckBox x:Name="EnableGifCheckBox" Content="启用GIF动画" Margin="0,0,0,8"
                              Checked="EnableGifCheckBox_Changed" Unchecked="EnableGifCheckBox_Changed"/>
                    <Separator Margin="0,5,0,5"/>
                    <TextBlock Text="🟡 黄灯GIF路径:" Margin="0,0,0,3"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBox x:Name="YellowGifPathTextBox" Text="" Width="170" Margin="0,0,5,0"/>
                        <Button Content="浏览" Click="BrowseYellowGif_Click" Width="50"/>
                    </StackPanel>
                    <Separator Margin="0,8,0,8"/>
                    <TextBlock Text="🔴 红灯GIF路径:" Margin="0,0,0,3"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBox x:Name="RedGifPathTextBox" Text="" Width="170" Margin="0,0,5,0"/>
                        <Button Content="浏览" Click="BrowseRedGif_Click" Width="50"/>
                    </StackPanel>
                    <Separator Margin="0,8,0,8"/>
                    <TextBlock Text="🟢 绿灯GIF路径:" Margin="0,0,0,3"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBox x:Name="GreenGifPathTextBox" Text="" Width="170" Margin="0,0,5,0"/>
                        <Button Content="浏览" Click="BrowseGreenGif_Click" Width="50"/>
                    </StackPanel>
                    <Separator Margin="0,8,0,8"/>
                    <Button Content="保存设置" Click="SaveGifSettings_Click" HorizontalAlignment="Stretch"/>
                </StackPanel>
            </MenuItem>
            <MenuItem Header="气泡设置" Visibility="Collapsed">
                <MenuItem.Icon>
                    <TextBlock>💬</TextBlock>
                </MenuItem.Icon>
                <StackPanel Width="180" Margin="5">
                    <CheckBox x:Name="ShowBubbleCheckBox" Content="始终显示气泡" Margin="0,0,0,5"/>
                    <Slider x:Name="BubbleLengthSlider" Minimum="10" Maximum="200" Value="50"/>
                </StackPanel>
            </MenuItem>
            <MenuItem Header="背景色">
                <MenuItem.Icon>
                    <TextBlock>🎨</TextBlock>
                </MenuItem.Icon>
                <StackPanel Width="180" Margin="5">
                    <TextBlock Text="选择预设颜色:" Margin="0,0,0,5"/>
                    <UniformGrid Columns="4" Rows="2" Margin="0,0,0,5">
                        <Button Height="28" Background="#444444" Click="BgColorPreset_Click" Tag="#444444"/>
                        <Button Height="28" Background="#555555" Click="BgColorPreset_Click" Tag="#555555" BorderBrush="#FFFFFF" BorderThickness="2"/>
                        <Button Height="28" Background="#666666" Click="BgColorPreset_Click" Tag="#666666"/>
                        <Button Height="28" Background="#777777" Click="BgColorPreset_Click" Tag="#777777"/>
                        <Button Height="28" Background="#888888" Click="BgColorPreset_Click" Tag="#888888"/>
                        <Button Height="28" Background="#2D3748" Click="BgColorPreset_Click" Tag="#2D3748"/>
                        <Button Height="28" Background="#1E3A5F" Click="BgColorPreset_Click" Tag="#1E3A5F"/>
                        <Button Height="28" Background="#3D1F1F" Click="BgColorPreset_Click" Tag="#3D1F1F"/>
                    </UniformGrid>
                    <TextBlock Text="自定义颜色 (#RRGGBB):" Margin="0,5,0,3"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBox x:Name="BgColorTextBox" Text="#555555" Width="90" Margin="0,0,5,0" PreviewKeyDown="BgColorTextBox_PreviewKeyDown"/>
                        <Button Content="应用" Click="ApplyBgColor_Click" Width="55"/>
                    </StackPanel>
                </StackPanel>
            </MenuItem>
            <MenuItem Header="日志设置">
                <MenuItem.Icon>
                    <TextBlock>📝</TextBlock>
                </MenuItem.Icon>
                <StackPanel Width="200" Margin="5">
                    <CheckBox x:Name="EnableLoggingCheckBox" Content="启用消息日志记录" Margin="0,0,0,10"
                              Checked="EnableLoggingCheckBox_Changed" Unchecked="EnableLoggingCheckBox_Changed"/>
                    <TextBlock Text="最大日志条数:" Margin="0,0,0,3"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBox x:Name="MaxLogEntriesTextBox" Text="100" Width="80" Margin="0,0,5,0"/>
                        <Button Content="应用" Click="ApplyMaxLogEntries_Click" Width="55"/>
                    </StackPanel>
                    <Separator Margin="0,10,0,10"/>
                    <Button Content="查看当前日志" Click="ViewLogs_Click" HorizontalAlignment="Stretch"/>
                    <Button Content="导出日志文件" Click="ExportLogs_Click" Margin="0,5,0,0" HorizontalAlignment="Stretch"/>
                    <Button Content="清空日志" Click="ClearLogs_Click" Margin="0,5,0,0" HorizontalAlignment="Stretch"/>
                </StackPanel>
            </MenuItem>
            <MenuItem Header="打开配置文件夹" Click="OpenConfigFolder_Click">
                <MenuItem.Icon>
                    <TextBlock>📂</TextBlock>
                </MenuItem.Icon>
            </MenuItem>
            <Separator/>
            <MenuItem Header="透明度">
                <Slider x:Name="OpacitySlider"
                        Minimum="0.3" Maximum="1.0"
                        Value="0.8"
                        Width="100"
                        ValueChanged="OpacitySlider_ValueChanged"/>
            </MenuItem>
            <Separator/>
            <MenuItem Header="开机启动" Click="AutoStartMenuItem_Click">
                <MenuItem.Icon>
                    <TextBlock>🚀</TextBlock>
                </MenuItem.Icon>
                <MenuItem.IsCheckable>True</MenuItem.IsCheckable>
            </MenuItem>
            <Separator/>
            <MenuItem Header="退出" Click="ExitMenuItem_Click">
                <MenuItem.Icon>
                    <TextBlock>❌</TextBlock>
                </MenuItem.Icon>
            </MenuItem>
        </ContextMenu>
    </Window.ContextMenu>

    <!-- 主容器 - 简洁灰色半透明 -->
    <Grid Opacity="{Binding WindowOpacity, ElementName=windowRoot}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <!-- 信号灯主容器 -->
        <Border x:Name="LightContainer"
                Grid.Column="0"
                Width="64"
                Height="184"
                CornerRadius="32"
                BorderThickness="1.5"
                BorderBrush="#777777"
                Background="#555555"
                Opacity="0.95"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
            <Border.Effect>
                <DropShadowEffect Color="#000000" BlurRadius="12" ShadowDepth="0" Opacity="0.4"/>
            </Border.Effect>

            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <!-- 黄灯 - 思考中 -->
                <Grid Width="42" Height="42" Margin="0,0,0,14">
                    <Ellipse x:Name="YellowLight"
                             Width="42" Height="42"
                             Fill="{StaticResource OffBrush}"
                             Stroke="#444444"
                             StrokeThickness="1.5"
                             Opacity="0.4">
                        <Ellipse.Effect>
                            <DropShadowEffect x:Name="YellowGlow"
                                              Color="#FFD700"
                                              BlurRadius="0"
                                              ShadowDepth="0"
                                              Opacity="0"/>
                        </Ellipse.Effect>
                    </Ellipse>
                    <Image x:Name="YellowGif"
                           Width="42" Height="42"
                           Visibility="Collapsed"
                           Stretch="UniformToFill"/>
                </Grid>

                <!-- 绿灯 - 输出中 -->
                <Grid Width="42" Height="42" Margin="0,0,0,14">
                    <Ellipse x:Name="GreenLight"
                             Width="42" Height="42"
                             Fill="{StaticResource OffBrush}"
                             Stroke="#444444"
                             StrokeThickness="1.5"
                             Opacity="0.4">
                        <Ellipse.Effect>
                            <DropShadowEffect x:Name="GreenGlow"
                                              Color="#00FF7F"
                                              BlurRadius="0"
                                              ShadowDepth="0"
                                              Opacity="0"/>
                        </Ellipse.Effect>
                    </Ellipse>
                    <Image x:Name="GreenGif"
                           Width="42" Height="42"
                           Visibility="Collapsed"
                           Stretch="UniformToFill"/>
                </Grid>

                <!-- 红灯 - 需要确认 -->
                <Grid Width="42" Height="42">
                    <Ellipse x:Name="RedLight"
                             Width="42" Height="42"
                             Fill="{StaticResource OffBrush}"
                             Stroke="#444444"
                             StrokeThickness="1.5"
                             Opacity="0.4">
                        <Ellipse.Effect>
                            <DropShadowEffect x:Name="RedGlow"
                                              Color="#FF4444"
                                              BlurRadius="0"
                                              ShadowDepth="0"
                                              Opacity="0"/>
                        </Ellipse.Effect>
                    </Ellipse>
                    <Image x:Name="RedGif"
                           Width="42" Height="42"
                           Visibility="Collapsed"
                           Stretch="UniformToFill"/>
                </Grid>
            </StackPanel>
        </Border>

        <!-- LED 发光文字 - 竖排显示 + 纵向滚动 -->
        <Border x:Name="LedTextContainer"
                Grid.Column="1"
                Width="30"
                Height="184"
                Margin="10,0,0,0"
                Background="#1A000000"
                CornerRadius="6"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                Visibility="Visible">

            <Canvas x:Name="LedCanvas" ClipToBounds="True" Height="184" Width="30">
                <!-- 竖排滚动的 LED 发光文字 -->
                <TextBlock x:Name="LedTextBlock"
                           FontSize="16"
                           FontWeight="Bold"
                           Canvas.Left="0"
                           Canvas.Top="0">
                    <TextBlock.Effect>
                        <DropShadowEffect x:Name="LedTextGlow"
                                          BlurRadius="10"
                                          ShadowDepth="0"
                                          Opacity="1"/>
                    </TextBlock.Effect>
                </TextBlock>
            </Canvas>
        </Border>
    </Grid>
</Window>
